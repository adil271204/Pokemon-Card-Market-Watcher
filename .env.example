# Database – for local dev you can use SQLite: sqlite:///./pokemon_watcher.db
# For production on Render, this is set automatically when linked to a Render Postgres instance
DATABASE_URL=

# Set to "true" to use mock eBay data (no real API keys needed)
USE_MOCK_EBAY=true

# eBay API credentials (only needed when USE_MOCK_EBAY=false)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_DE

# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
