# Database – leave empty locally to use SQLite fallback
# On Render this is set automatically from the linked Postgres instance
DATABASE_URL=

# Set to "true" to use mock eBay data (no real API keys needed)
USE_MOCK_EBAY=true

# eBay API credentials (only needed when USE_MOCK_EBAY=false)
# Get keys at: https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_DE
# "production" or "sandbox" (sandbox = eBay test environment, no real listings)
EBAY_ENV=production
# How many listings to fetch per page (max 200 per eBay API docs)
EBAY_SEARCH_LIMIT=50

# Location filter – only save/alert listings from these countries
# Default: EU countries only. UK/GB excluded due to import duties after Brexit.
EBAY_ALLOWED_COUNTRIES=DE,AT,FR,IT,ES,NL,BE,PL,IE,PT,SE,FI,DK,CZ,SK,SI,HU,HR,RO,BG,GR,LT,LV,EE,LU,MT,CY
EBAY_EXCLUDED_COUNTRIES=GB,UK,US,CN,JP,CA,AU
# Set to true to allow listings without a country (default: false = reject unknown)
EBAY_ALLOW_UNKNOWN_LOCATION=false
# Backfill: how many days back to look for active listings
EBAY_LOOKBACK_DAYS=14
# Backfill: max number of pages to fetch per search
EBAY_MAX_PAGES=5

# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard password – if empty, no login required
DASHBOARD_PASSWORD=

# Session secret – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
