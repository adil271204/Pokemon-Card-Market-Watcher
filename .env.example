# Database – leave empty locally to use SQLite fallback
# On Render this is set automatically from the linked Postgres instance
DATABASE_URL=

# Set to "true" to use mock eBay data (no real API keys needed)
USE_MOCK_EBAY=true

# eBay API credentials (only needed when USE_MOCK_EBAY=false)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_DE

# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard password – if empty, no login required
DASHBOARD_PASSWORD=

# Session secret – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
